# TAKE ONE Nexus - Environment Variables Example

# --- Database Configuration ---
DB_HOST=your_database_host
DB_PORT=3306
DB_NAME=take_one
DB_USER=your_database_user
DB_PASSWORD=your_database_password
# DATABASE_URL=mysql://user:pass@host:port/db

# --- Authentication ---
JWT_SECRET=your_jwt_secret_here_at_least_32_chars

# --- SMTP Configuration (Collaboration notifications) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_smtp_app_password
MAIL_FROM=TAKE ONE Nexus <your_email@gmail.com>

# --- CORS & Security ---
# ALLOWED_ORIGINS=https://my-custom-domain.com

# --- Environment ---
NODE_ENV=development
PORT=3000

# --- Pusher (Real-time Chat) ---
PUSHER_APP_ID=your_pusher_app_id
NEXT_PUBLIC_PUSHER_KEY=your_pusher_key
PUSHER_SECRET=your_pusher_secret
NEXT_PUBLIC_PUSHER_CLUSTER=your_pusher_cluster

# --- Resend (Transactional Email) ---
# Get key at https://resend.com → API Keys
RESEND_API_KEY=re_your_resend_api_key

# --- App URL (used for verification/reset email links) ---
# Production: https://takeone-nexus.net.in
NEXT_PUBLIC_APP_URL=https://takeone-nexus.net.in

# --- PostHog (Analytics, Session Replay, Feature Flags) ---
# Used ONLY for frontend analytics and session replay — NOT for error tracking
# Get key at https://app.posthog.com → Project Settings
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_project_key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# --- Sentry (Backend Error Monitoring ONLY) ---
# Used ONLY for API failures, DB errors, server exceptions — NOT for analytics
# Get DSN at https://sentry.io → Your Project → SDK Setup → DSN
SENTRY_DSN=https://your_key@sentry.io/your_project_id
