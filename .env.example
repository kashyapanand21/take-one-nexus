# TAKE ONE Nexus - Environment Variables Example

# --- Database Configuration ---
# Your MySQL host (e.g., localhost or cloud provider like PlanetScale/Aiven)
DB_HOST=your_database_host
DB_PORT=3306
DB_NAME=take_one
DB_USER=your_database_user
DB_PASSWORD=your_database_password

# Alternatively, use a single connection string if your provider supports it
# DATABASE_URL=mysql://user:pass@host:port/db

# --- Authentication ---
# A long, random string (at least 32 characters) to sign JWT tokens
JWT_SECRET=your_jwt_secret_here

# --- SMTP Configuration (Notifications) ---
# Used for collaboration request emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_smtp_app_password
MAIL_FROM=TAKE ONE Nexus <your_email@gmail.com>

# --- CORS & Security ---
# Comma-separated list of extra allowed origins (e.g., custom domains)
# ALLOWED_ORIGINS=https://my-custom-domain.com

# --- Environment ---
NODE_ENV=development
PORT=3000

# --- Pusher Configuration (Real-time Chat) ---
PUSHER_APP_ID=your_pusher_app_id
NEXT_PUBLIC_PUSHER_KEY=your_pusher_key
PUSHER_SECRET=your_pusher_secret
NEXT_PUBLIC_PUSHER_CLUSTER=your_pusher_cluster
