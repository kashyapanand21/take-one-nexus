{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "public/**",
          "routes/**",
          "config/**",
          "middleware/**",
          "utils/**",
          "database/**"
        ]
      }
    },
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/_next/(.*)",
      "dest": "/_next/$1"
    },
    {
      "src": "/admin(/(.*)|$)",
      "dest": "/admin$1"
    },
    {
      "src": "/profile",
      "dest": "/profile"
    },
    {
      "src": "/crew\\.htm",
      "dest": "server.js"
    },
    {
      "src": "/crew",
      "status": 308,
      "headers": {
        "Location": "/crew.htm"
      }
    },
    {
      "src": "/legal",
      "dest": "/legal"
    },
    {
      "src": "/moderation",
      "dest": "/moderation"
    },
    {
      "src": "/chat",
      "dest": "/chat"
    },
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/styles/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/scripts/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/assets/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/((?!admin|api|_next|profile|crew|legal|moderation|chat|developer).*)",
      "dest": "server.js"
    }
  ]
}
