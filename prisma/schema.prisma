generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                  Int                    @id @default(autoincrement()) @db.UnsignedInt
  name                String                 @db.VarChar(120)
  email               String                 @unique(map: "uq_users_email") @db.VarChar(150)
  password            String                 @db.VarChar(255)
  role                String?                @db.VarChar(100)
  college             String?                @db.VarChar(150)
  city                String?                @db.VarChar(120)
  bio                 String?                @db.Text
  skills              String?                @db.Text
  portfolio           String?                @db.VarChar(255)
  avatar_url          String?                @db.VarChar(255)
  created_at                  DateTime               @default(now()) @db.Timestamp(0)
  updated_at                  DateTime               @default(now()) @updatedAt @db.Timestamp(0)
  gender                      String?                @db.VarChar(20)
  credits                     Int                    @default(0) @db.UnsignedInt
  display_preference          String?                @default("Show Real Name Only") @db.VarChar(50)
  screen_name                 String?                @db.VarChar(100)
  social_links                String?                @db.Text
  email_verified              Boolean                @default(false)
  email_verified_at           DateTime?              @db.Timestamp(0)
  verification_token          String?                @unique(map: "uq_users_verification_token") @db.VarChar(255)
  verification_token_expires  DateTime?              @db.Timestamp(0)
  reset_token                 String?                @unique(map: "uq_users_reset_token") @db.VarChar(255)
  reset_token_expires         DateTime?              @db.Timestamp(0)
  collaboration_owned CollaborationRequest[] @relation("OwnedRequests")
  collaboration_reqs  CollaborationRequest[] @relation("RequesterRequests")
  issues              Issue[]
  sent_messages       Message[]              @relation("SentMessages")
  notifications       notifications[]
  scripts             Script[]
  memberships         ConversationMember[]
  transactions        CreditTransaction[]

  @@map("users")
}

model Script {
  id                 Int                    @id @default(autoincrement()) @db.UnsignedInt
  user_id            Int?                   @db.UnsignedInt
  title              String                 @db.VarChar(180)
  genre              String?                @db.VarChar(80)
  synopsis           String?                @db.Text
  poster_url         String?                @db.VarChar(255)
  roles_needed       String?                @db.VarChar(255)
  status             String                 @default("Open for collaboration") @db.VarChar(80)
  created_at         DateTime               @default(now()) @db.Timestamp(0)
  updated_at         DateTime               @default(now()) @updatedAt @db.Timestamp(0)
  media_links        String?                @db.Text
  role_data          String?                @db.Text
  work_type          String                 @default("Script") @db.VarChar(50)
  collaboration_reqs CollaborationRequest[]
  user               User?                  @relation(fields: [user_id], references: [id])

  @@index([user_id], map: "idx_scripts_user_id")
  @@index([genre], map: "idx_scripts_genre")
  @@map("scripts")
}

model CollaborationRequest {
  id           Int      @id @default(autoincrement()) @db.UnsignedInt
  script_id    Int      @db.UnsignedInt
  requester_id Int      @db.UnsignedInt
  owner_id     Int      @db.UnsignedInt
  message      String?  @db.Text
  status       String   @default("pending") @db.VarChar(40)
  created_at   DateTime @default(now()) @db.Timestamp(0)
  updated_at   DateTime @default(now()) @updatedAt @db.Timestamp(0)
  owner        User     @relation("OwnedRequests", fields: [owner_id], references: [id], onDelete: Cascade)
  requester    User     @relation("RequesterRequests", fields: [requester_id], references: [id], onDelete: Cascade)
  script       Script   @relation(fields: [script_id], references: [id], onDelete: Cascade)

  @@unique([script_id, requester_id], map: "uq_script_requester")
  @@index([owner_id], map: "idx_requests_owner_id")
  @@index([requester_id], map: "idx_requests_requester_id")
  @@map("collaboration_requests")
}

model Conversation {
  id         Int                  @id @default(autoincrement()) @db.UnsignedInt
  created_at DateTime             @default(now()) @db.Timestamp(0)
  updated_at DateTime             @default(now()) @updatedAt @db.Timestamp(0)
  avatar_url String?              @db.VarChar(255)
  is_group   Boolean              @default(false)
  name       String?              @db.VarChar(255)
  messages   Message[]
  members    ConversationMember[]
  tasks      Task[]

  @@map("conversations")
}

model ConversationMember {
  id              Int          @id @default(autoincrement()) @db.UnsignedInt
  conversation_id Int          @db.UnsignedInt
  user_id         Int          @db.UnsignedInt
  role            String       @default("Member") @db.VarChar(50)
  joined_at       DateTime     @default(now()) @db.Timestamp(0)
  conversation    Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  user            User         @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([conversation_id, user_id])
  @@map("conversation_members")
}

model Task {
  id              Int          @id @default(autoincrement()) @db.UnsignedInt
  conversation_id Int          @db.UnsignedInt
  creator_id      Int          @db.UnsignedInt
  assignee_id     Int?         @db.UnsignedInt
  title           String       @db.VarChar(255)
  description     String?      @db.Text
  status          String       @default("Pending") @db.VarChar(50)
  priority        String       @default("Medium") @db.VarChar(50)
  due_date        DateTime?    @db.Timestamp(0)
  reward_credits  Int          @default(0) @db.UnsignedInt
  approval_status String       @default("Pending") @db.VarChar(50)
  completed_at    DateTime?    @db.Timestamp(0)
  approved_at     DateTime?    @db.Timestamp(0)
  created_at      DateTime     @default(now()) @db.Timestamp(0)
  updated_at      DateTime     @default(now()) @updatedAt @db.Timestamp(0)
  conversation    Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@map("tasks")
}

model CreditTransaction {
  id          Int      @id @default(autoincrement()) @db.UnsignedInt
  user_id     Int      @db.UnsignedInt
  amount      Int      @db.Int
  reason      String   @db.VarChar(255)
  type        String   @db.VarChar(20) // 'CREDIT' or 'DEBIT'
  created_at  DateTime @default(now()) @db.Timestamp(0)
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("credit_transactions")
}

model Issue {
  id          Int      @id @default(autoincrement()) @db.UnsignedInt
  user_id     Int?     @db.UnsignedInt
  title       String   @db.VarChar(255)
  description String   @db.Text
  location    String?  @db.VarChar(255)
  severity    String   @default("low") @db.VarChar(50)
  screenshot  String?  @db.VarChar(255)
  status      String   @default("open") @db.VarChar(50)
  created_at  DateTime @default(now()) @db.Timestamp(0)
  updated_at  DateTime @default(now()) @updatedAt @db.Timestamp(0)
  user        User?    @relation(fields: [user_id], references: [id])

  @@index([user_id], map: "issues_user_id_fkey")
  @@map("issues")
}

model Message {
  id              Int          @id @default(autoincrement()) @db.UnsignedInt
  conversation_id Int          @db.UnsignedInt
  sender_id       Int?         @db.UnsignedInt
  content         String       @db.Text
  is_read         Boolean      @default(false)
  created_at      DateTime     @default(now()) @db.Timestamp(0)
  conversation    Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  sender          User?        @relation("SentMessages", fields: [sender_id], references: [id])

  @@index([conversation_id], map: "idx_messages_conversation_id")
  @@index([sender_id], map: "idx_messages_sender_id")
  @@map("messages")
}

model notifications {
  id         Int      @id @default(autoincrement()) @db.UnsignedInt
  user_id    Int      @db.UnsignedInt
  type       String   @db.VarChar(80)
  title      String   @db.VarChar(160)
  body       String?  @db.Text
  link_url   String?  @db.VarChar(255)
  is_read    Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamp(0)
  updated_at DateTime @default(now()) @db.Timestamp(0)
  users      User     @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "fk_notifications_user")

  @@index([user_id, is_read, created_at], map: "idx_notifications_user_read")
}
