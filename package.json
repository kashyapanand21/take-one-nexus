{
  "name": "take-one-backend",
  "version": "1.0.0",
  "description": "Backend API for TAKE ONE, a film crew and script collaboration platform.",
  "main": "server.js",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "postinstall": "prisma generate",
    "start": "next start",
"legacy:dev": "set PORT=5001 && nodemon -L --watch server.js --watch routes --watch config --ext js,json server.js",    "legacy:start": "node server.js",
    "lint": "eslint src --ext .ts,.tsx,.js,.jsx",
    "db:init": "node database/init.js",
    "db:seed": "node database/seed.js"
  },
  "keywords": [
    "take-one",
    "film",
    "crew",
    "scripts",
    "express"
  ],
  "author": "TAKE ONE",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@sentry/nextjs": "^10.53.1",
    "@sentry/node": "^10.53.1",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "jose": "^6.2.3",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^1.14.0",
    "mysql2": "^3.11.5",
    "next": "^16.2.4",
    "nodemailer": "^6.10.1",
